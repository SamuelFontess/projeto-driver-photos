# Copie para .env e preencha os valores reais
# Gere secrets com: openssl rand -hex 32

# ─── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_DB=driver
POSTGRES_USER=driver
POSTGRES_PASSWORD=GERAR_COM_OPENSSL_RAND_HEX_32

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=GERAR_COM_OPENSSL_RAND_HEX_32
REFRESH_JWT_SECRET=GERAR_COM_OPENSSL_RAND_HEX_32

# ─── URLs ────────────────────────────────────────────────────────────────────
# URL pública do frontend (usada pelo backend no CORS e emails)
FRONTEND_URL=https://seudominio.com

# ─── Brevo (email) ───────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_FROM=seuemail@dominio.com
BREVO_FROM_NAME=Driver App

# ─── Email worker ─────────────────────────────────────────────────────────────
EMAIL_PROVIDER=brevo
EMAIL_WORKER_ADMIN_API_KEY=GERAR_COM_OPENSSL
EMAIL_QUEUE_KEY=driver:email:events

# ─── Upload ──────────────────────────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_MB=10

# ─── Rate limit (valores padrão, ajustar se necessário) ──────────────────────
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=15

# ─── Cache de preview ────────────────────────────────────────────────────────
FILE_PREVIEW_CACHE_TTL_SECONDS=3600
FILE_PREVIEW_CACHE_MAX_BYTES=20971520
FILE_PREVIEW_MAX_BYTES=52428800

# ─── Recuperação de senha ────────────────────────────────────────────────────
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── Admin ───────────────────────────────────────────────────────────────────
# Emails separados por vírgula que terão acesso ao painel admin
ADMIN_EMAILS=seuemail@dominio.com

# ─── Docs (Scalar API reference) ─────────────────────────────────────────────
DOCS_USER=admin
DOCS_PASSWORD=SENHA_FORTE_AQUI

# ─── Watchtower (pull de imagens privadas no ghcr.io) ────────────────────────
GITHUB_TOKEN=ghp_...
