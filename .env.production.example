# Copie para .env e preencha os valores reais
# Gere secrets com: openssl rand -hex 64

# ─── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_DB=driver
POSTGRES_USER=driver
POSTGRES_PASSWORD=SENHA_FORTE_AQUI

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=GERAR_COM_OPENSSL_RAND_HEX_64
REFRESH_JWT_SECRET=GERAR_COM_OPENSSL_RAND_HEX_64

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://seudominio.com
NEXT_PUBLIC_API_URL=https://api.seudominio.com

# ─── Brevo (email) ───────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_FROM=seuemail@gmail.com
BREVO_FROM_NAME=Driver App

# ─── Upload ──────────────────────────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_MB=10

# ─── Rate limit (valores padrão, ajustar se necessário) ──────────────────────
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=15

# ─── Cache ───────────────────────────────────────────────────────────────────
FILE_PREVIEW_CACHE_TTL_SECONDS=3600
FILE_PREVIEW_CACHE_MAX_BYTES=20971520
FILE_PREVIEW_MAX_BYTES=52428800

# ─── Email queue ─────────────────────────────────────────────────────────────
EMAIL_QUEUE_KEY=driver:email:events
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ─── Docs (Scalar API reference) ─────────────────────────────────────────────
DOCS_USER=admin
DOCS_PASSWORD=SENHA_FORTE_AQUI
