PORT=3000
FRONTEND_URL=http://localhost:3001
DATABASE_URL="postgresql://usuario:senha@localhost:5432/drive_db?schema=public"

# JWT — REQUIRED: server refuses to start without these
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_JWT_SECRET=change-me-to-a-different-long-random-string

# Redis — BullMQ email queue
REDIS_URL=redis://localhost:6379

# Redis — Preview cache (separate instance with allkeys-lru)
# In docker-compose this is redis-cache:6379; locally can share the same instance
REDIS_CACHE_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=300
FILE_PREVIEW_CACHE_TTL_SECONDS=3600
FILE_PREVIEW_CACHE_MAX_BYTES=20971520
FILE_PREVIEW_MAX_BYTES=52428800

# Email queue
EMAIL_QUEUE_KEY=driver:email:events

# Brevo (email provider)
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM=noreply@yourdomain.com
BREVO_FROM_NAME=Driver App

# Auth / reset password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Admin access — comma-separated list of admin email addresses
ADMIN_EMAILS=admin@yourdomain.com

# Firebase — required for file upload/download/preview
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# API Docs basic auth (GET /api-docs)
DOCS_USER=admin
DOCS_PASSWORD=change-me

# Cookie security — set to true in production (requires HTTPS)
COOKIE_SECURE=false

# Upload limits
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Rate limits (optional — defaults shown)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=15
FORGOT_PASSWORD_RATE_LIMIT_MAX=5
